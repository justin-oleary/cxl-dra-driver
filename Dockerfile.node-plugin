FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /cxl-node-plugin ./cmd/node-plugin

# DRA node plugin must run as root to access kubelet directories
FROM gcr.io/distroless/static
COPY --from=builder /cxl-node-plugin /cxl-node-plugin
ENTRYPOINT ["/cxl-node-plugin"]
